{
  "expo": {
    "name": "Truth or Dare",
    "slug": "truth-or-dare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Truth or Dare to access your photos for sharing.",
          "cameraPermission": "Allow Truth or Dare to use your camera for dares.",
          "microphonePermission": "Allow Truth or Dare to use your microphone for video dares."
        }
      ],
      "expo-font",
      "expo-image",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-web-browser",
      "expo-audio"
    ],
    "android": {
      "package": "com.truthdare.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8adad93d-f4e8-4c47-bd92-6231427fa469"
      }
    },
    "owner": "bikrampoudel01"
  }
}
