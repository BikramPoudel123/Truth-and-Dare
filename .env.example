# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SOCKET_PATH=/
NODE_ENV=production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TLS=false

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
